---
import houseIcon from '../assets/114ebae2afe3a8a82f1ffeca9290fb1759e0ab3a.png';
import iosIcon from '../assets/ios-icon-logo.png';
import { siteConfig } from '../modules/content';

type HeaderLocale = 'en' | 'ru';

interface LanguageLink {
  locale: HeaderLocale;
  href: string;
  label: string;
  flag: string;
}

interface Props {
  locale?: HeaderLocale;
  languageLinks?: LanguageLink[];
}

const { locale = 'en', languageLinks = [] } = Astro.props;

const labels: Record<HeaderLocale, {
  houseAlt: string;
  tips: string;
  tipsHref: string;
  languageSwitcher: string;
  appStore: string;
  appStoreShort: string;
  appStoreAlt: string;
}> = {
  en: {
    houseAlt: 'Vault House',
    tips: 'Tips',
    tipsHref: '/en/tips/',
    languageSwitcher: 'Choose language',
    appStore: 'Download on iOS',
    appStoreShort: 'iOS',
    appStoreAlt: 'iOS App Store',
  },
  ru: {
    houseAlt: 'Дом Vault',
    tips: 'Советы',
    tipsHref: '/tips/',
    languageSwitcher: 'Выбрать язык',
    appStore: 'Скачать на iOS',
    appStoreShort: 'iOS',
    appStoreAlt: 'iOS App Store',
  },
};

const copy = labels[locale];
---

<header class="p-4 lg:p-6">
  <div class="max-w-6xl mx-auto flex items-center justify-between gap-2 sm:gap-3">
    <a href="/" class="text-2xl sm:text-4xl lg:text-5xl text-white drop-shadow-lg flex items-center gap-1.5 sm:gap-3 no-underline flex-shrink-0">
      <img
        src={houseIcon.src}
        alt={copy.houseAlt}
        class="w-8 h-8 sm:w-12 sm:h-12 lg:w-16 lg:h-16 object-contain"
      />
      Vault
    </a>
    <nav class="flex items-center gap-1.5 sm:gap-4">
      <a
        href={copy.tipsHref}
        class="text-white/90 hover:text-white text-xs sm:text-base lg:text-lg font-medium transition-colors"
      >
        {copy.tips}
      </a>
      {languageLinks.length > 1 && (
        <div
          role="group"
          class="flex items-center rounded-full bg-white/15 p-0.5 shadow-md ring-1 ring-white/25"
          aria-label={copy.languageSwitcher}
        >
          {languageLinks.map((language) => (
            <a
              href={language.href}
              lang={language.locale}
              title={language.label}
              aria-label={language.label}
              aria-current={language.locale === locale ? 'page' : undefined}
              class:list={[
                'flex h-8 w-8 sm:h-9 sm:w-9 items-center justify-center rounded-full text-base sm:text-lg leading-none transition-all duration-200',
                language.locale === locale
                  ? 'bg-white text-gray-900 shadow-sm'
                  : 'text-white hover:bg-white/20 hover:text-white',
              ]}
            >
              <span aria-hidden="true">{language.flag}</span>
              <span class="sr-only">{language.label}</span>
            </a>
          ))}
        </div>
      )}
      <a
        href={siteConfig.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="app-badge hidden sm:flex items-center gap-2 text-base lg:text-lg px-4 lg:px-6 py-2.5 lg:py-3 bg-black text-white hover:bg-gray-800 shadow-lg btn-animated rounded-md font-medium flex-shrink-0"
      >
        <img src={iosIcon.src} alt={copy.appStoreAlt} />
        {copy.appStore}
      </a>
      <a
        href={siteConfig.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="app-badge flex sm:hidden items-center gap-1 text-xs px-2 py-2 bg-black text-white hover:bg-gray-800 shadow-lg btn-animated rounded-md font-medium flex-shrink-0"
      >
        <img src={iosIcon.src} alt={copy.appStoreAlt} />
        {copy.appStoreShort}
      </a>
    </nav>
  </div>
</header>
