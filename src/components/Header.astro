---
import houseIcon from '../assets/114ebae2afe3a8a82f1ffeca9290fb1759e0ab3a.png';
import iosIcon from '../assets/ios-icon-logo.png';
import {
  getHomePath,
  getTipsPath,
  localeMeta,
  siteConfig,
  siteContentByLocale,
  type SiteLocale,
} from '../modules/content';

interface LanguageLink {
  locale: SiteLocale;
  href: string;
  label: string;
  flag: string;
}

interface Props {
  locale?: SiteLocale;
  languageLinks?: LanguageLink[];
}

const { locale = 'en', languageLinks = [] } = Astro.props;
const copy = siteContentByLocale[locale].header;
const homeHref = getHomePath(locale);
const tipsHref = getTipsPath(locale);
const currentLanguage =
  languageLinks.find((language) => language.locale === locale) ?? {
    locale,
    href: homeHref,
    label: localeMeta[locale].label,
    flag: localeMeta[locale].flag,
  };
---

<header class="p-4 lg:p-6">
  <div class="max-w-6xl mx-auto flex items-center justify-between gap-2 sm:gap-3">
    <a href={homeHref} class="text-2xl sm:text-4xl lg:text-5xl text-white drop-shadow-lg flex items-center gap-1.5 sm:gap-3 no-underline flex-shrink-0">
      <img
        src={houseIcon.src}
        alt={copy.houseAlt}
        class="w-8 h-8 sm:w-12 sm:h-12 lg:w-16 lg:h-16 object-contain"
      />
      Vault
    </a>
    <nav class="flex items-center gap-1.5 sm:gap-4">
      <a
        href={tipsHref}
        class="inline-flex h-9 sm:h-10 items-center justify-center rounded-full bg-white px-3 sm:px-4 text-xs sm:text-sm lg:text-base font-bold text-orange-700 shadow-md ring-1 ring-white/70 transition-all duration-200 hover:bg-orange-50 hover:text-orange-800 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-orange-500"
      >
        {copy.tips}
      </a>
      {languageLinks.length > 1 && (
        <details class="group relative">
          <summary
            class="flex h-9 sm:h-10 cursor-pointer list-none items-center gap-1.5 rounded-full bg-white/95 px-2.5 sm:px-3 text-gray-900 shadow-md ring-1 ring-white/60 transition-all duration-200 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-orange-500 [&::-webkit-details-marker]:hidden"
            aria-label={copy.languageSwitcher}
            title={copy.languageSwitcher}
          >
            <span class="text-base sm:text-lg leading-none" aria-hidden="true">{currentLanguage.flag}</span>
            <span class="hidden sm:inline text-xs font-bold uppercase tracking-wide">{currentLanguage.locale}</span>
            <span class="text-[0.65rem] leading-none text-gray-500 transition-transform duration-200 group-open:rotate-180" aria-hidden="true">
              ▼
            </span>
            <span class="sr-only">{currentLanguage.label}</span>
          </summary>
          <div class="absolute right-0 z-50 mt-2 w-56 max-h-[70vh] overflow-y-auto rounded-2xl bg-white/95 p-2 text-gray-900 shadow-2xl ring-1 ring-black/10 backdrop-blur">
            {languageLinks.map((language) => (
              <a
                href={language.href}
                lang={localeMeta[language.locale].htmlLang}
                title={language.label}
                aria-label={language.label}
                aria-current={language.locale === locale ? 'page' : undefined}
                class:list={[
                  'flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-semibold transition-colors duration-150',
                  language.locale === locale
                    ? 'bg-orange-100 text-orange-800'
                    : 'text-gray-700 hover:bg-orange-50 hover:text-orange-800',
                ]}
              >
                <span class="text-lg leading-none" aria-hidden="true">{language.flag}</span>
                <span class="min-w-0 flex-1 truncate">{language.label}</span>
                <span class="text-[0.65rem] font-bold uppercase text-gray-400">{language.locale}</span>
              </a>
            ))}
          </div>
        </details>
      )}
      <a
        href={siteConfig.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="app-badge hidden sm:flex items-center gap-2 text-base lg:text-lg px-4 lg:px-6 py-2.5 lg:py-3 bg-black text-white hover:bg-gray-800 shadow-lg btn-animated rounded-md font-medium flex-shrink-0"
      >
        <img src={iosIcon.src} alt={copy.appStoreAlt} />
        {copy.appStore}
      </a>
      <a
        href={siteConfig.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="app-badge flex sm:hidden items-center gap-1 text-xs px-2 py-2 bg-black text-white hover:bg-gray-800 shadow-lg btn-animated rounded-md font-medium flex-shrink-0"
      >
        <img src={iosIcon.src} alt={copy.appStoreAlt} />
        {copy.appStoreShort}
      </a>
    </nav>
  </div>
</header>
