---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { tipsContentByLocale, type TipsLocale } from '../modules/content';

interface Props {
  locale: TipsLocale;
}

const { locale } = Astro.props;
const page = tipsContentByLocale[locale];
const localizedPages = Object.values(tipsContentByLocale);
const alternatePages = localizedPages.filter((alternatePage) => alternatePage.locale !== page.locale);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.headline,
  description: page.description,
  author: { '@type': 'Organization', name: 'Vault Game' },
  publisher: { '@type': 'Organization', name: 'Vault Game' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': page.canonicalUrl },
  datePublished: page.datePublished,
  dateModified: page.dateModified,
};

const getSectionClass = (sectionId: string) => (sectionId === 'conclusion' ? 'mb-8' : 'mb-12');
const getTitleClass = (kind: string) =>
  kind === 'intro' || kind === 'paragraphs'
    ? 'flex items-start gap-3 text-xl sm:text-2xl lg:text-3xl font-bold text-gray-800 mb-4'
    : 'flex items-start gap-3 text-xl sm:text-2xl lg:text-3xl font-bold text-gray-800 mb-6';
---

<BaseLayout
  title={page.title}
  description={page.description}
  ogTitle={page.title}
  ogDescription={page.description}
  ogType="article"
  ogImage={page.ogImage}
  ogImageAlt={page.ogImageAlt}
  canonicalUrl={page.canonicalUrl}
  lang={page.htmlLang}
>
  <Fragment slot="head">
    <meta name="keywords" content={page.keywords} />
    <meta property="og:locale" content={page.ogLocale} />
    {alternatePages.map((alternatePage) => (
      <meta property="og:locale:alternate" content={alternatePage.ogLocale} />
    ))}
    {localizedPages.map((localizedPage) => (
      <link rel="alternate" hreflang={localizedPage.htmlLang} href={localizedPage.canonicalUrl} />
    ))}
    <link rel="alternate" hreflang="x-default" href={tipsContentByLocale.en.canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <Header locale={page.locale} />

  <main class="p-3 sm:p-4 lg:p-6">
    <article class="max-w-4xl mx-auto bg-white/95 backdrop-blur-sm rounded-[1.25rem] sm:rounded-3xl p-5 sm:p-8 lg:p-12 shadow-xl">
      <header class="text-center mb-10">
        <div class="relative overflow-hidden rounded-2xl border border-orange-200 bg-orange-50 px-4 py-7 sm:px-8 sm:py-9">
          <img
            src={page.hero.icon}
            alt=""
            aria-hidden="true"
            class="mx-auto mb-4 h-16 w-16 sm:h-20 sm:w-20 object-contain"
          />
          <h1 class="relative z-10 text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-900 mb-4 leading-tight">
            {page.hero.title}
          </h1>
          <p class="relative z-10 mx-auto max-w-2xl text-sm sm:text-base text-gray-600">
            {page.hero.subtitle}
          </p>
          <img
            src={page.hero.leftDecorIcon}
            alt=""
            aria-hidden="true"
            class="hidden sm:block absolute left-5 top-6 h-14 w-14 rotate-[-10deg] object-contain opacity-90"
          />
          <img
            src={page.hero.rightDecorIcon}
            alt=""
            aria-hidden="true"
            class="hidden sm:block absolute right-5 bottom-5 h-16 w-16 rotate-[8deg] object-contain opacity-90"
          />
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          {page.quickTips.map((tip) => (
            <div class="flex items-start gap-3 rounded-2xl border border-orange-100 bg-orange-50/70 p-4 text-left">
              <img src={tip.icon} alt="" aria-hidden="true" class="h-10 w-10 flex-shrink-0 object-contain" />
              <div class="min-w-0">
                <p class="text-base font-bold text-gray-900">{tip.title}</p>
                <p class="mt-1 text-sm leading-relaxed text-gray-600">{tip.text}</p>
              </div>
            </div>
          ))}
        </div>
      </header>

      {page.sections.map((section) => (
        <section id={section.id} class={getSectionClass(section.id)}>
          <h2 class={getTitleClass(section.kind)}>
            <img src={section.icon} alt="" aria-hidden="true" class="h-9 w-9 sm:h-10 sm:w-10 flex-shrink-0 object-contain" />
            <span class="min-w-0 leading-tight break-words hyphens-auto">{section.title}</span>
          </h2>

          {(section.kind === 'intro' || section.kind === 'paragraphs') && (
            <div>
              {(section.paragraphs ?? []).map((paragraph, paragraphIndex) => (
                <p class:list={['text-gray-700 leading-relaxed', paragraphIndex > 0 && 'mt-4']}>
                  {paragraph}
                </p>
              ))}
            </div>
          )}

          {(section.kind === 'grouped-list' || section.kind === 'table') &&
            (section.groups ?? []).map((group, groupIndex) => (
              <>
                <h3 class="text-xl lg:text-2xl font-bold text-gray-700 mb-3">{group.heading}</h3>
                <ul
                  class:list={[
                    'list-disc pl-5 sm:pl-6 space-y-4 text-gray-700 leading-relaxed',
                    groupIndex < (section.groups?.length ?? 0) - 1 || section.kind === 'table' ? 'mb-8' : '',
                  ]}
                >
                  {group.items.map((item) => (
                    <li>
                      <strong>{item.title}</strong> {item.text}
                    </li>
                  ))}
                </ul>
              </>
            ))}

          {section.kind === 'table' && section.table && (
            <>
              <h3 class="text-xl lg:text-2xl font-bold text-gray-700 mb-3">{section.table.heading}</h3>
              <div class="overflow-x-auto mb-8">
                <table class="w-full table-fixed border-collapse text-sm text-gray-700">
                  <thead>
                    <tr class="bg-orange-50">
                      {section.table.headers.map((header) => (
                        <th class="border border-orange-200 px-3 sm:px-4 py-3 text-left align-top font-bold break-words">
                          {header}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {section.table.rows.map((row, rowIndex) => (
                      <tr class:list={[rowIndex % 2 === 1 && 'bg-orange-50/50']}>
                        <td class="border border-orange-100 px-3 sm:px-4 py-3 align-top font-medium break-words">
                          {row.label}
                        </td>
                        <td class="border border-orange-100 px-3 sm:px-4 py-3 align-top break-words">
                          {row.description}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}

          {section.kind === 'ordered-list' && (
            <ol class="list-decimal pl-5 sm:pl-6 space-y-4 text-gray-700 leading-relaxed">
              {(section.items ?? []).map((item) => (
                <li>
                  <strong>{item.title}</strong> {item.text}
                </li>
              ))}
            </ol>
          )}
        </section>
      ))}

      <div class="text-center mt-10 pt-8 border-t border-gray-200">
        <p class="text-gray-600 mb-4">{page.cta.text}</p>
        <a
          href={page.cta.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full sm:w-auto items-center justify-center gap-2 bg-orange-600 hover:bg-orange-700 text-white text-base sm:text-lg px-5 sm:px-8 py-3 sm:py-4 rounded-full shadow-lg hover:shadow-2xl btn-animated"
        >
          {page.cta.label}
        </a>
      </div>
    </article>
  </main>

  <Footer locale={page.locale} />
</BaseLayout>
